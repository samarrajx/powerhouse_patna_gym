{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "backend/api/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/index.js"
    },
    {
      "source": "/admin/assets/(.*)",
      "destination": "/admin-web-panel/dist/assets/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin-web-panel/dist/index.html"
    },
    {
      "source": "/admin",
      "destination": "/admin-web-panel/dist/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/landing/$1"
    }
  ]
}
