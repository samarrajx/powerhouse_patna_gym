{
  "name": "powerhouse-gym-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run admin\"",
    "backend": "cd backend && npm start",
    "admin": "cd admin-web-panel && npm run dev",
    "build": "npm run build-admin && npm run install-backend && cp -rv admin-web-panel/dist/* .",
    "build-admin": "cd admin-web-panel && npm install && npm run build",
    "install-backend": "cd backend && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
